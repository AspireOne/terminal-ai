{
  "name": "@aspireone/terminal-ai",
  "description": "Effortless AI in your terminal.",
  "type": "commonjs",
  "version": "0.16.4",
  "main": "./dist/cli.js",
  "bin": {
    "ai": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "start": "node ./scripts/run-ts-node.cjs ./src/cli.ts",
    "start:debug": "node --no-warnings --inspect-brk ./node_modules/ts-node/dist/bin.js ./src/cli.ts",
    "init": "node ./scripts/init.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "node ./scripts/run-jest.cjs --no-coverage",
    "test:debug": "node --experimental-vm-modules --no-warnings --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --no-coverage",
    "test:watch": "node ./scripts/run-jest.cjs --watch --no-coverage",
    "test:cov": "node ./scripts/run-jest.cjs --coverage",
    "test:install": "node ./scripts/test-install.cjs",
    "test:e2e": "node ./scripts/test-chat.cjs && node ./scripts/test-file-input.cjs",
    "test:e2e:assistants": "node ./scripts/test-chat.cjs ai --assistant && node ./scripts/test-file-input.cjs ai --assistant",
    "tsc": "tsc",
    "relink": "npm run build && npm unlink ai && npm link ai",
    "postinstall": "echo \"Terminal AI installed! Run 'ai' to try it out.\"",
    "prepare": "git config core.hooksPath .husky/_"
  },
  "files": [
    "dist",
    "prompts"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dwmkerr/terminal-ai.git"
  },
  "author": "dwmkerr",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dwmkerr/terminal-ai/issues"
  },
  "homepage": "https://github.com/dwmkerr/terminal-ai#readme",
  "dependencies": {
    "@dwmkerr/ai-providers-and-models": "^0.1.13",
    "@dwmkerr/inquirer-advanced-input-prompt": "^0.1.0",
    "@inquirer/prompts": "^7.3.1",
    "clipboardy": "^4.0.0",
    "colors": "^1.4.0",
    "commander": "^11.1.0",
    "debug": "^4.3.4",
    "inquirer-file-selector": "^0.6.2",
    "isbinaryfile": "^5.0.4",
    "js-yaml": "^4.1.0",
    "langfuse": "^3.36.0",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0",
    "mime-types": "^3.0.1",
    "openai": "^4.83.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^2.1.4",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.53.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "mock-fs": "^5.2.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
